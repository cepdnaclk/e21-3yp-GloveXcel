# Choose your database mode: mongo, postgres, or both
DB_CLIENT=both

# MongoDB (used when DB_CLIENT=mongo)
MONGO_URI=mongodb://username:password@host:27017/database

# PostgreSQL / Supabase (used when DB_CLIENT=postgres)
POSTGRES_HOST=db.your-project-ref.supabase.co
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DATABASE=postgres
POSTGRES_PORT=5432
POSTGRES_SSL=true
POSTGRES_SSL_REJECT_UNAUTHORIZED=false

# API server
PORT=3000
